# Primary LLM — required for natural language queries
OPENAI_API_KEY=your_openai_api_key_here

# Optional fallback LLM (Gemini). If OPENAI_API_KEY is set, this is ignored.
GEMINI_API_KEY=

# Database paths (default values work for local dev)
DATABASE_PATH=data/o2c.db
DATA_DIR=data/sap-o2c-data
UPLOAD_DIR=data/uploads
BROWSE_BASE_DIR=data

# CORS — comma-separated list of allowed frontend origins
# For local dev: http://localhost:3000,http://localhost:5173
# For production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
